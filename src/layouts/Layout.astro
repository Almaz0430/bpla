---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- SEO Meta Tags -->
		<title>Противодействие для БПЛА | Защита Инфраструктуры в Казахстане</title>
		<meta name="description" content="Комплексные системы мониторинга, обнаружения и подавления несанкционированных БПЛА. Защита промышленных, военных и государственных объектов в Казахстане. Системы РЭБ, антидрон комплексы, обнаружение и нейтрализация беспилотников." />
		<meta name="keywords" content="БПЛА, антидрон, защита от дронов, подавление БПЛА, обнаружение дронов, мониторинг БПЛА, Казахстан, безопасность объектов, UAV, UAS, система РЭБ, антидрон комплекс, противодействие беспилотникам, защита инфраструктуры, Астана, Алматы, антидрон ружье, антидрон радар, защита периметра, нейтрализация дронов, counter-UAS" />
		<meta name="author" content="KAZ-BPLA" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href="https://www.kaz-bpla.kz/" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.kaz-bpla.kz/" />
		<meta property="og:title" content="Противодействие БПЛА | Защита Инфраструктуры в Казахстане" />
		<meta property="og:description" content="Комплексные системы мониторинга, обнаружения и подавления несанкционированных БПЛА. Защита промышленных и государственных объектов в Казахстане." />
		<meta property="og:image" content="https://www.kaz-bpla.kz/logo.png" />
		<meta property="og:locale" content="ru_RU" />
		<meta property="og:site_name" content="KAZ-BPLA" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://www.kaz-bpla.kz/" />
		<meta property="twitter:title" content="Противодействие БПЛА | Защита Инфраструктуры в Казахстане" />
		<meta property="twitter:description" content="Комплексные системы мониторинга, обнаружения и подавления несанкционированных БПЛА. Защита промышленных и государственных объектов в Казахстане." />
		<meta property="twitter:image" content="https://www.kaz-bpla.kz/logo.png" />

		<!-- Structured Data -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "KAZ-BPLA",
			"url": "https://www.kaz-bpla.kz/",
			"logo": "https://www.kaz-bpla.kz/logo.png",
			"description": "Комплексные системы мониторинга, обнаружения и подавления несанкционированных БПЛА. Защита промышленных и государственных объектов в Казахстане.",
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Астана",
				"addressCountry": "KZ"
			},
			"contactPoint": {
				"@type": "ContactPoint",
				"telephone": "+7-777-855-55-56",
				"contactType": "sales",
				"availableLanguage": ["Russian", "Kazakh"]
			},
			"sameAs": []
		}
		</script>

		<!-- Favicons -->
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="apple-mobile-web-app-title" content="UAV-KZ" />
		<meta name="theme-color" content="#000000" />

		<meta name="generator" content={Astro.generator} />
		
		<!-- Resource Hints for faster loading -->
		<link rel="preload" href="/hero/video-1.webm" as="video" type="video/webm" />
		<link rel="preload" href="/logo-130.webp" as="image" />
		<link rel="preload" href="/logo_2-90.webp" as="image" />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #000000;
		--bg-secondary: #0a0a0a;
		--text-color: #e0e0e0;
		--text-muted: #888888;
		--accent-color: #ffffff;
		--accent-color-hover: #cccccc;
		--border-color: #222222;
	}
	* {
		box-sizing: border-box;
	}
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
		font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
		background-color: var(--bg-color);
		color: var(--text-color);
		scroll-behavior: smooth;
	}

	h1, h2, h3, h4, h5, h6 {
		font-family: 'Arial Black', 'Segoe UI', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}
	a {
		color: var(--accent-color);
		text-decoration: none;
		transition: color 0.3s ease;
	}
	a:hover {
		color: var(--accent-color-hover);
	}
</style>
