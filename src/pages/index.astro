---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { siWhatsapp } from "simple-icons";
---

<Layout>
	<!-- Hero Section -->
	<section class="hero">
		<Header />
		<div class="video-background">
			<video
				id="video-1"
				class="hero-video active"
				autoplay
				muted
				playsinline
				preload="auto"
			>
				<source src="/hero/video-1.webm" type="video/webm" />
			</video>
			<video
				id="video-2"
				class="hero-video"
				muted
				playsinline
				preload="none"></video>
			<audio id="bg-audio" loop autoplay>
				<source src="/hero/sound.mp3" type="audio/mpeg" />
			</audio>
			<div class="overlay"></div>
		</div>

		<div class="hero-content">
			<h1 class="visually-hidden">Противодействие БПЛА — Системы защиты от дронов в Казахстане</h1>
			<!-- Audio tap hint -->
			<button
				id="audio-hint"
				class="audio-hint"
				aria-label="Включить звук"
			>
				<span class="audio-hint-icon">
					<svg
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"
						></polygon>
						<path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
						<path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
					</svg>
				</span>
				<span class="audio-hint-text">Включить звук</span>
			</button>
			<p class="hero-desc">
				Комплексная система по обнаружению, идентификации и
				нейтрализации беспилотников, включающая радиоэлектронную борьбу
				и физическое уничтожение БПЛА
			</p>
		</div>

		<a href="#about" class="scroll-arrow" aria-label="Прокрутить вниз">
			<div class="mouse">
				<div class="wheel"></div>
			</div>
			<div class="arrow-container">
				<span class="chevron"></span>
				<span class="chevron"></span>
			</div>
		</a>

		<script>
			const videoUrls = [
				"/hero/video-1.webm",
				"/hero/video-2.mp4",
				"/hero/video-3.mp4",
				"/hero/video-4.mp4",
				"/hero/video-5.mp4",
				"/hero/video-6.mp4",
				"/hero/video-7.mp4",
			];
			let currentIndex = 0;
			const v1 = document.getElementById("video-1") as HTMLVideoElement;
			const v2 = document.getElementById("video-2") as HTMLVideoElement;
			const players = [v1, v2];
			let activePlayerIndex = 0;
			const audio = document.getElementById(
				"bg-audio",
			) as HTMLAudioElement;

			// Per-video object-position overrides (mobile: shift specific videos)
			const videoPositions: Record<string, string> = {
				"/hero/video-7.mp4": "30% center",
			};

			const applyVideoPosition = (
				player: HTMLVideoElement,
				url: string,
			) => {
				player.style.objectPosition =
					videoPositions[url] ?? "center center";
			};

			const transition = () => {
				const nextIndex = (currentIndex + 1) % videoUrls.length;
				const nextPlayerIndex = (activePlayerIndex + 1) % 2;

				const currentPlayer = players[activePlayerIndex];
				const nextPlayer = players[nextPlayerIndex];

				// Pre-set source and play the next video hidden
				nextPlayer.src = videoUrls[nextIndex];
				applyVideoPosition(nextPlayer, videoUrls[nextIndex]);
				nextPlayer.play();

				// Smooth fade
				nextPlayer.classList.add("active");
				currentPlayer.classList.remove("active");

				currentIndex = nextIndex;
				activePlayerIndex = nextPlayerIndex;

				// Re-attach time listener to the new current player
				nextPlayer.addEventListener("timeupdate", checkTime, {
					once: true,
				});
			};

			const checkTime = (e: Event) => {
				const player = e.target as HTMLVideoElement;
				// Start transition 1.5s before current video ends
				if (
					player.duration > 0 &&
					player.duration - player.currentTime < 1.5
				) {
					transition();
				} else {
					player.addEventListener("timeupdate", checkTime, {
						once: true,
					});
				}
			};

			// Initialize
			v1.addEventListener("timeupdate", checkTime, { once: true });

			// Scroll to top on load (fix mobile browser restoring scroll position)
			window.scrollTo({ top: 0, behavior: "instant" });

			// Audio hint button
			const audioHint = document.getElementById(
				"audio-hint",
			) as HTMLButtonElement;

			const hideHint = () => {
				if (audioHint) {
					audioHint.classList.add("hidden");
				}
			};

			// Audio handling: try immediate play, fallback to interaction if blocked
			const startAudio = () => {
				if (audio) {
					audio
						.play()
						.then(() => {
							// Autoplay succeeded — hide hint
							hideHint();
						})
						.catch(() => {
							console.log("Autoplay blocked, showing hint");
							// Show hint with animation
							if (audioHint) audioHint.classList.add("visible");
							// Click on hint button
							if (audioHint) {
								audioHint.addEventListener(
									"click",
									() => {
										audio.play();
										hideHint();
									},
									{ once: true },
								);
							}
							// Also allow any click/touch anywhere as fallback
							document.addEventListener(
								"click",
								() => {
									audio.play();
									hideHint();
								},
								{ once: true },
							);
							document.addEventListener(
								"touchstart",
								() => {
									audio.play();
									hideHint();
								},
								{ once: true },
							);
						});
				}
			};
			startAudio();
		</script>
	</section>

	<!-- About Section -->
	<section id="about" class="about-section">
		<div class="container">
			<div class="bento-grid">
				<div class="bento-item bento-large">
					<div class="dual-images" id="dual-images-slider">
						<img
							src="/photo/image_5-720.webp"
							srcset="/photo/image_5-360.webp 360w, /photo/image_5-720.webp 720w"
							sizes="(max-width: 768px) 100vw, 717px"
							width="720"
							height="415"
							alt="Защита объектов 2"
							loading="lazy"
							decoding="async"
						/>
						<img
							src="/photo/image_4-720.webp"
							srcset="/photo/image_4-360.webp 360w, /photo/image_4-720.webp 720w"
							sizes="(max-width: 768px) 100vw, 717px"
							width="720"
							height="415"
							alt="Защита объектов 1"
							loading="lazy"
							decoding="async"
						/>
					</div>
					<script>
						(function () {
							const slider =
								document.getElementById("dual-images-slider");
							if (!slider) return;
							let scrolling = true;
							setInterval(() => {
								if (!scrolling) return;
								const maxScroll =
									slider.scrollWidth - slider.clientWidth;
								if (slider.scrollLeft >= maxScroll - 2) {
									slider.scrollTo({
										left: 0,
										behavior: "smooth",
									});
								} else {
									slider.scrollBy({
										left: slider.clientWidth,
										behavior: "smooth",
									});
								}
							}, 3000);
							slider.addEventListener("touchstart", () => {
								scrolling = false;
							});
							slider.addEventListener("touchend", () => {
								setTimeout(() => {
									scrolling = true;
								}, 3000);
							});
						})();
					</script>
				</div>

				<div class="bento-features">
					<div class="bento-item hover-card">
						<div
							class="card-bg"
							style="background-image: url('/photo/card_1.webp');"
						>
						</div>
						<div class="card-front">
							<p>Автономная работа в режиме 24/7</p>
						</div>
					</div>

					<div class="bento-item hover-card">
						<div
							class="card-bg"
							style="background-image: url('/photo/card_2.webp');"
						>
						</div>
						<div class="card-front">
							<p>Защита пограничных объектов и военных частей</p>
						</div>
					</div>

					<div class="bento-item hover-card">
						<div
							class="card-bg"
							style="background-image: url('/photo/card_3.webp');"
						>
						</div>
						<div class="card-front">
							<p>
								Защита заводов и промышленных объектов
								Казахстана
							</p>
						</div>
					</div>

					<div class="bento-item hover-card">
						<div
							class="card-bg"
							style="background-image: url('/photo/card_4.webp');"
						>
						</div>
						<div class="card-front">
							<p>
								Административных зданий и объектов
								инфраструктуры
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- SEO Section -->
	<section class="seo-section visually-hidden">
		<div class="container container-sm">
			<div class="seo-content">
				<h2>Системы защиты от БПЛА в Казахстане</h2>
				<p>В условиях стремительного развития беспилотных технологий, обеспечение безопасности критически важных объектов становится приоритетной задачей. Наша компания предлагает передовые решения в области противодействия беспилотным летательным аппаратам (БПЛА) на территории Республики Казахстан. Мы специализируемся на внедрении систем радиоэлектронной борьбы (РЭБ), радиолокационного мониторинга и физического подавления несанкционированных дронов.</p>
				<p>Наши антидрон-комплексы разработаны с учетом современных угроз и способны эффективно обнаруживать, идентифицировать и нейтрализовать беспилотники различных типов в автоматическом режиме 24/7. Мы предлагаем индивидуальный подход к каждому проекту, будь то защита промышленных предприятий, правительственных учреждений, аэропортов, объектов энергетической инфраструктуры или военных баз.</p>
				<h3>Почему выбирают наши системы противодействия дронам?</h3>
				<ul>
					<li><strong>Высокая точность обнаружения:</strong> Использование многоспектральных сенсоров, оптико-электронных систем и радаров позволяет фиксировать БПЛА даже в сложных погодных условиях.</li>
					<li><strong>Надежное подавление:</strong> Системы радиоэлектронной борьбы (РЭБ) блокируют каналы управления, навигации (GPS, ГЛОНАСС) и передачи видеосигнала дрона, вынуждая его совершить посадку или вернуться на базу.</li>
					<li><strong>Интеграция и масштабируемость:</strong> Оборудование легко интегрируется в существующие системы безопасности объектов, обеспечивая единый контур защиты.</li>
					<li><strong>Законность и безопасность:</strong> Все поставляемые комплексы соответствуют законодательству Республики Казахстан и стандартам безопасности.</li>
				</ul>
				<p>Инвестируя в системы защиты от БПЛА, вы минимизируете риски шпионажа, террористических актов и несанкционированного вмешательства в работу вашей инфраструктуры. Обеспечьте безопасность своего бизнеса вместе с профессионалами!</p>
			</div>
		</div>
	</section>

	<!-- Contacts Section -->
	<section id="contacts" class="contacts-section">
		<div class="container">
			<div class="contacts-header text-center">
				<span class="section-subtitle">Контакты</span>
				<h2>Связаться с нами</h2>
			</div>
			<div class="contacts-grid">
				<!-- Location -->
				<div class="contact-card">
					<div class="contact-card-icon-wrap">
						<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#EA4335" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
							<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
							<circle cx="12" cy="10" r="3"/>
						</svg>
					</div>
					<p class="contact-card-label">Адрес</p>
					<p class="contact-card-value">Астана, Казахстан</p>
				</div>

				<!-- WhatsApp -->
				<a class="contact-card contact-card-link" href="https://wa.me/77778555556" target="_blank" rel="noopener noreferrer">
					<div class="contact-card-icon-wrap">
						<svg role="img" viewBox="0 0 24 24" width="36" height="36" xmlns="http://www.w3.org/2000/svg">
							<path d={siWhatsapp.path} fill="#25D366" />
						</svg>
					</div>
					<p class="contact-card-label">WhatsApp</p>
					<p class="contact-card-value">
						Написать сообщение
						<svg class="arrow-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
					</p>
				</a>

				<!-- Phone -->
				<a class="contact-card contact-card-link" href="tel:+77778555556">
					<div class="contact-card-icon-wrap">
						<svg viewBox="0 0 24 24" width="36" height="36" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#007AFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
						</svg>
					</div>
					<p class="contact-card-label">Телефон</p>
					<p class="contact-card-value">
						+7 (777) 855-55-56
						<svg class="arrow-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
					</p>
				</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Hero Section */
	.hero {
		position: relative;
		height: 100vh;
		height: 100dvh;
		min-height: 600px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		text-align: center;
	}

	.video-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 1;
		background: #000;
	}

	.hero-video {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		min-width: 100%;
		min-height: 100%;
		width: auto;
		height: auto;
		object-fit: cover;
		object-position: center center;
		opacity: 0;
		transition: opacity 1.5s ease-in-out;
	}

	.hero-video.active {
		opacity: 1;
	}

	.overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(18, 18, 18, 0.5); /* Dark overlay */
		z-index: 2;
	}

	.hero-content {
		position: absolute;
		bottom: 110px;
		left: 0;
		right: 0;
		margin: 0 auto;
		z-index: 3;
		max-width: 900px;
		padding: 0 20px;
		animation: fadeIn 1.5s ease-out;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero-eyebrow {
		font-size: 0.85rem;
		font-weight: 400;
		letter-spacing: 3px;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.6);
		margin-bottom: 8px;
	}

	.hero-content h1 {
		font-family: "Russo One", sans-serif;
		font-size: clamp(3rem, 7vw, 6rem);
		font-weight: 400;
		margin-bottom: 20px;
		letter-spacing: 0.5px;
		color: #ffffff;
		line-height: 1.1;
		text-transform: uppercase;
	}

	.hero-desc {
		font-size: 1.1rem;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.9);
		max-width: 700px;
		line-height: 1.6;
		margin-top: 5px;
	}

	/* Audio hint button */
	.audio-hint {
		position: relative;
		z-index: 4;
		display: none;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		background: transparent;
		border: none;
		padding: 10px;
		cursor: pointer;
		color: #ffffff;
		font-family: inherit;
		transition: all 0.3s ease;
		opacity: 0;
		margin-bottom: 15px;
	}

	.audio-hint.visible {
		display: flex;
		animation: hintAppear 0.8s ease forwards;
	}

	.audio-hint.hidden {
		opacity: 0 !important;
		pointer-events: none;
	}

	.audio-hint:hover {
		transform: scale(1.1);
		color: #ffffff;
	}

	.audio-hint-icon {
		width: 32px;
		height: 32px;
		display: flex;
		align-items: center;
		justify-content: center;
		animation: pulseCustom 2s infinite;
	}

	.audio-hint-text {
		font-size: 0.75rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: rgba(255, 255, 255, 0.8);
		white-space: nowrap;
	}

	@keyframes pulseCustom {
		0% {
			transform: scale(1);
			opacity: 1;
		}
		50% {
			transform: scale(1.1);
			opacity: 0.7;
		}
		100% {
			transform: scale(1);
			opacity: 1;
		}
	}

	@keyframes hintAppear {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes tapWiggle {
		0%,
		100% {
			transform: rotate(0deg) translateY(0);
		}
		20% {
			transform: rotate(-15deg) translateY(-3px);
		}
		40% {
			transform: rotate(10deg) translateY(-1px);
		}
		60% {
			transform: rotate(-8deg) translateY(-2px);
		}
		80% {
			transform: rotate(5deg) translateY(0);
		}
	}

	.scroll-arrow {
		position: absolute;
		bottom: 30px;
		left: 50%;
		transform: translateX(-50%);
		z-index: 3;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		text-decoration: none;
		transition: opacity 0.3s ease;
	}

	.scroll-arrow:hover {
		opacity: 0.8;
	}

	.mouse {
		width: 24px;
		height: 38px;
		border: 2px solid rgba(255, 255, 255, 0.4);
		border-radius: 12px;
		position: relative;
	}

	.wheel {
		width: 3px;
		height: 6px;
		background: #ffffff;
		border-radius: 2px;
		position: absolute;
		top: 6px;
		left: 50%;
		transform: translateX(-50%);
		animation: scrollWheel 1.8s infinite;
	}

	.arrow-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-top: -2px;
	}

	.chevron {
		display: block;
		width: 10px;
		height: 10px;
		border-right: 2px solid rgba(255, 255, 255, 0.5);
		border-bottom: 2px solid rgba(255, 255, 255, 0.5);
		transform: rotate(45deg);
		margin: -4px 0;
		animation: chevronAnim 1.8s infinite;
	}

	.chevron:nth-child(2) {
		animation-delay: 0.2s;
	}

	@keyframes scrollWheel {
		0% {
			opacity: 1;
			transform: translateX(-50%) translateY(0);
		}
		100% {
			opacity: 0;
			transform: translateX(-50%) translateY(15px);
		}
	}

	@keyframes chevronAnim {
		0% {
			opacity: 0;
			transform: rotate(45deg) translate(-5px, -5px);
		}
		40% {
			opacity: 1;
		}
		80% {
			opacity: 0;
			transform: rotate(45deg) translate(5px, 5px);
		}
		100% {
			opacity: 0;
		}
	}

	/* Sections General */
	section {
		padding: 100px 0;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.container-sm {
		max-width: 900px;
	}

	.text-center {
		text-align: center;
	}

	/* Section Headers */
	.section-header {
		margin-bottom: 60px;
	}

	.section-header.text-center {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.section-subtitle {
		display: inline-block;
		font-size: 0.85rem;
